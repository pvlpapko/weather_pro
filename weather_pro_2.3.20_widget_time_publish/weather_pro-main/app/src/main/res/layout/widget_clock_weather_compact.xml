<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRootClock"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_initial_dark"
    android:orientation="vertical"
    android:paddingLeft="7dp"
    android:paddingTop="6dp"
    android:paddingRight="7dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/widgetClockArea"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.15"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingRight="5dp">

            <TextView
                android:id="@+id/widgetClockTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autoSizeMaxTextSize="46sp"
                android:autoSizeMinTextSize="20sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:text="13:07"
                android:textColor="#F8FAFC"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetClockDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:text="вс, 14 июн"
                android:textColor="#E2E8F0"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widgetClockHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:text="@string/widget_alarm_hint"
                android:textColor="#E2E8F0"
                android:textSize="8sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widgetWeatherArea"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.9"
            android:gravity="right|center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widgetCity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autoSizeMaxTextSize="10sp"
                android:autoSizeMinTextSize="8sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:ellipsize="end"
                android:gravity="right"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Фёдоровский"
                android:textColor="#E2E8F0"
                android:textSize="9sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="right|center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widgetWeatherIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:shadowColor="#99000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="3"
                    android:text="☁"
                    android:textColor="#F8FAFC"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/widgetTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:autoSizeMaxTextSize="30sp"
                    android:autoSizeMinTextSize="16sp"
                    android:autoSizeStepGranularity="1sp"
                    android:autoSizeTextType="uniform"
                    android:gravity="right"
                    android:includeFontPadding="false"
                    android:layout_marginLeft="3dp"
                    android:maxLines="1"
                    android:shadowColor="#99000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="3"
                    android:text="18°"
                    android:textColor="#F8FAFC"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/widgetCondition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="right"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="пасмурно"
                android:textColor="#F8FAFC"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widgetEffect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="right"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text=""
        android:textColor="#E2E8F0"
        android:textSize="8sp" />

    <TextView
        android:id="@+id/widgetUpdated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="right"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="Д:18° · Н:10°"
        android:textColor="#E2E8F0"
        android:textSize="9sp" />
</LinearLayout>
