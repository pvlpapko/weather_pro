<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRootClock"
        android:clickable="true"
        android:focusable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_initial_dark"
    android:baselineAligned="false"
    android:orientation="horizontal"
    android:paddingLeft="8dp"
    android:paddingTop="5dp"
    android:paddingRight="8dp"
    android:paddingBottom="5dp">

    <LinearLayout
        android:id="@+id/widgetClockArea"
        android:clickable="true"
        android:focusable="true"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.08"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingRight="5dp">

        <TextClock
            android:id="@+id/widgetClockTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="none"
            android:format12Hour="h:mm"
            android:format24Hour="HH:mm"
            android:fontFamily="sans-serif-condensed"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:singleLine="true"
            android:textColor="#F8FAFC"
            android:textSize="56sp"
            android:textStyle="bold" />

        <TextClock
            android:id="@+id/widgetClockDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:format12Hour="EEE, d MMM"
            android:format24Hour="EEE, d MMM"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="2"
            android:singleLine="true"
            android:textColor="#E2E8F0"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widgetClockHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="2"
            android:singleLine="true"
            android:text="@string/widget_alarm_hint"
            android:textColor="#E2E8F0"
            android:textSize="9sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widgetWeatherArea"
        android:clickable="true"
        android:focusable="true"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.92"
        android:gravity="center_vertical|right"
        android:orientation="vertical"
        android:paddingLeft="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="right|center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widgetCity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="right|center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:singleLine="true"
                android:text="Федоровский"
                android:textColor="#E2E8F0"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widgetSettingsButton"
                android:layout_width="32dp"
                android:layout_height="30dp"
                android:layout_marginLeft="6dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="⚙"
                android:textColor="#E2E8F0"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="right|center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/widgetWeatherImage"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter"
                android:src="@drawable/weather_real_partly" />

            <TextView
                android:id="@+id/widgetTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:gravity="right|center_vertical"
                android:includeFontPadding="false"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:text="19°"
                android:textColor="#F8FAFC"
                android:textSize="42sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/widgetEffect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="right"
            android:includeFontPadding="false"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="2"
            android:text=""
            android:textColor="#E2E8F0"
            android:textSize="9sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widgetCondition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="right"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:singleLine="true"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="2"
            android:text="почти ясно"
            android:textColor="#F8FAFC"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widgetUpdated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="right"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:singleLine="true"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="2"
            android:text="Д:20° · Н:10°"
            android:textColor="#E2E8F0"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>
