<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/previewClockRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_preview_real"
    android:baselineAligned="false"
    android:orientation="horizontal"
    android:paddingLeft="8dp"
    android:paddingTop="5dp"
    android:paddingRight="8dp"
    android:paddingBottom="5dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.08"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingRight="5dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:singleLine="true"
            android:text="13:07"
            android:textColor="#F8FAFC"
            android:textSize="54sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:singleLine="true"
            android:text="сб, 4 июл"
            android:textColor="#E2E8F0"
            android:textSize="11sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:singleLine="true"
            android:text="будильник / таймер"
            android:textColor="#E2E8F0"
            android:textSize="9sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.92"
        android:gravity="center_vertical|right"
        android:orientation="vertical"
        android:paddingLeft="5dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="right"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:singleLine="true"
            android:text="Федоровский  *"
            android:textColor="#E2E8F0"
            android:textSize="10sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="right|center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter"
                android:src="@drawable/weather_real_partly" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false"
                android:text="18°"
                android:textColor="#F8FAFC"
                android:textSize="42sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="right"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:singleLine="true"
            android:text="пасмурно"
            android:textColor="#F8FAFC"
            android:textSize="11sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="right"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:singleLine="true"
            android:text="День 20° - Ночь 10°"
            android:textColor="#E2E8F0"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>
